{
  "component": {
    "heading": {
      "mark": {
        "highlight": {
          "backgroundColor": {
            "$type": "color",
            "$value": "{base.color.highlited.200}"
          },
          "foregroundColor": {
            "$type": "color",
            "$value": "{semantic.color.text.default}"
          },
          "fontWeight": {
            "$type": "number",
            "$value": "{base.font.weight.extraBold}"
          },
          "paddingBlock": {
            "$type": "dimension",
            "$value": "0.02em"
          },
          "paddingInline": {
            "$type": "dimension",
            "$value": "0.14em"
          },
          "shadow": {
            "$type": "shadow",
            "$value": "{semantic.shadow.sm}"
          }
        },
        "underline": {
          "color": {
            "$type": "color",
            "$value": "{base.color.accent.600}"
          },
          "height": {
            "$type": "dimension",
            "$value": "0.32em"
          },
          "offset": {
            "$type": "dimension",
            "$value": "-0.16em"
          }
        }
      }
    }
  }
}
